# S&M Investments — Environment Variables

ANTHROPIC_API_KEY=              # https://console.anthropic.com

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Stock market data (Polygon is primary, Yahoo Finance is automatic fallback — no key needed)
