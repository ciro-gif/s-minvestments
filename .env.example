# Copy this file to .env for local development
# Set all of these as Netlify environment variables in production

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Alpha Vantage (free tier: https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your_key_here

# NewsAPI.org (free tier: https://newsapi.org/register)
NEWS_API_KEY=your_key_here

# Supabase (expose to frontend via JS config.js — public keys)
# These go in public/js/config.js, not here
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=eyJ...
